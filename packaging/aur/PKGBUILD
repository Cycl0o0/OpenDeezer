# Maintainer: Cycl0o0 <cyclolysis0@gmail.com>
# OpenDeezer terminal client (builds from the tagged source).
pkgname=opendeezer
pkgver=0.4.1
pkgrel=1
pkgdesc="Terminal Deezer client — browse and stream in HiFi with your Premium ARL"
arch=('x86_64' 'aarch64')
url="https://github.com/Cycl0o0/OpenDeezer"
license=('AGPL-3.0-or-later')
depends=('alsa-lib')
makedepends=('go' 'git')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
# Replace with the real checksum after tagging (updpkgsums), or keep SKIP for VCS use.
sha256sums=('SKIP')

build() {
  cd "OpenDeezer-$pkgver"
  export CGO_ENABLED=1
  export GOFLAGS="-trimpath -mod=readonly -modcacherw"
  export GOPATH="$srcdir/gopath"
  go build -ldflags "-s -w -X main.version=$pkgver" -o opendeezer ./cmd/opendeezer
}

package() {
  cd "OpenDeezer-$pkgver"
  install -Dm755 opendeezer "$pkgdir/usr/bin/opendeezer"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
